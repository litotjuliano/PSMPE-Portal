# Copy this file to .env and fill in real values for local development.
# NEVER commit the real .env file.

# ---------- PostgreSQL ----------
POSTGRES_DB=psmpe_portal
POSTGRES_USER=psmpe_user
POSTGRES_PASSWORD=change-me-locally
POSTGRES_PORT=5432

# Used by the backend container (Npgsql connection string, Docker Compose service name as host)
ConnectionStrings__DefaultConnection=Host=postgres;Port=5432;Database=psmpe_portal;Username=psmpe_user;Password=change-me-locally

# ---------- JWT ----------
# Generate a long random string for local dev, e.g.: openssl rand -base64 48
Jwt__Key=replace-with-a-long-random-secret-at-least-32-characters
Jwt__Issuer=PSMPE.Portal
Jwt__Audience=PSMPE.Portal.Client
Jwt__ExpiryMinutes=60

# ---------- Default seeded Super Admin (created on first run only) ----------
SEED_ADMIN_EMAIL=admin@psmpe.local
SEED_ADMIN_PASSWORD=ChangeMe123!
Seed__Enabled=true

# ---------- OpenAI ----------
# TODO: obtain a real key from https://platform.openai.com and set it here or as a DO App Platform secret.
OpenAI__ApiKey=sk-replace-me
OpenAI__Model=gpt-4o-mini

# ---------- Frontend ----------
VITE_API_BASE_URL=http://localhost:5000

# ---------- ASP.NET Core ----------
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:8080
