# Copy this file to .env and fill in real values for local development.
# NEVER commit the real .env file.

# ---------- PostgreSQL ----------
POSTGRES_DB=psmpe_portal
POSTGRES_USER=psmpe_user
POSTGRES_PASSWORD=change-me-locally
POSTGRES_PORT=5432

# Used by the backend container (Npgsql connection string, Docker Compose service name as host)
ConnectionStrings__DefaultConnection=Host=postgres;Port=5432;Database=psmpe_portal;Username=psmpe_user;Password=change-me-locally

# ---------- JWT ----------
# Generate a long random string for local dev, e.g.: openssl rand -base64 48
Jwt__Key=replace-with-a-long-random-secret-at-least-32-characters
Jwt__Issuer=PSMPE.Portal
Jwt__Audience=PSMPE.Portal.Client
Jwt__ExpiryMinutes=60

# ---------- Default seeded Super Admin (created on first run only) ----------
SEED_ADMIN_EMAIL=admin@psmpe.local
SEED_ADMIN_PASSWORD=ChangeMe123!

# One demo account per non-Super-Admin role (Admin/Manager/Accounts/Member), created on first
# run only, for local dev/QA - see openspecs/roles.md and the login page's dev credential
# cheatsheet. Leave unset in production to skip seeding these accounts entirely.
SEED_DEFAULT_PASSWORD=ChangeMe123!

Seed__Enabled=true

# ---------- OpenAI ----------
# TODO: obtain a real key from https://platform.openai.com and set it here or as a DO App Platform secret.
OpenAI__ApiKey=sk-replace-me
OpenAI__Model=gpt-4o-mini

# ---------- Frontend ----------
VITE_API_BASE_URL=http://localhost:5000

# Read by the backend to build email-verification links (which open the frontend app, not the
# API) - see openspecs/auth.md.
Frontend__BaseUrl=http://localhost:5173

# ---------- SMTP (email verification) ----------
# Leave Smtp__Host unset to fall back to ConsoleEmailSender (logs instead of sending - fine for
# local dev). Set these to send real verification emails, e.g. from litxus.com's mail provider.
Smtp__Host=
Smtp__Port=587
Smtp__Username=
Smtp__Password=
Smtp__From=noreply@litxus.com
Smtp__FromName=PSMPE Portal

# ---------- ASP.NET Core ----------
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:8080
